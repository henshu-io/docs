{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Henshu",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/welcome",
              "getting-started/concepts",
              "getting-started/first-episode"
            ]
          },
          {
            "group": "Editing",
            "pages": [
              "creating/uploading-audio",
              "editing/organizing",
              "editing/editing-audio",
              "editing/ai-enhancement",
              "editing/background-music"
            ]
          },
          {
            "group": "Publishing",
            "pages": [
              "publishing/generating",
              "publishing/show-notes",
              "publishing/downloading"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/plans-and-quotas",
              "account/subscription",
              "account/notifications"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Henshu App",
          "href": "https://app.henshu.io",
          "icon": "microphone"
        },
        {
          "anchor": "Website",
          "href": "https://henshu.io",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "height": 24
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@henshu.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Henshu",
      "href": "https://app.henshu.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "noIndex": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/henshu_io"
    }
  }
}
